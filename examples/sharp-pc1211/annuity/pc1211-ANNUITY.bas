PROGRAM "ANNUITY"
10:"A":REM *** INPUT ALL VARIABLES ***
20:INPUT "N:",Z
30:INPUT "I:",X
40:INPUT "PV:",C
50:INPUT "PMT:",V
60:INPUT "FV:",B:END
100:"Z":REM *** N ***
110:T=270:INPUT "APPROX N:",T
120:O=INT(V*10+.5)/10:I=0
130:Z=T:GOSUB 900:R=INT((C*W-B)/E*10+.5)/10:I=I+1
140:IF R=O GOTO 160
150:T=T*R/V*R/V:GOTO 130
160:R=INT(Z*100+.5)/100
170:PRINT "N=",USING;R
190:R=INT(Z/.12+.5)/100
190:PRINT "N/12=",R:END
200:"X":REM *** I ***
210:T=1:INPUT "APPROX I:",T
220:O=INT(V*10+.5)/10:I=0
230:X=T:GOSUB 900:R=INT((C*W-B)/E*10+.5)/10:I=I+1
240:IF R=O GOTO 260
250:T=T*V/R:GOTO 230
260:R=INT(X*100000+.5)/100000
270:PRINT "I=",USING;R
280:R=INT(X*120000+.5)/10000
290:PRINT "I*12=",R:END
300:"C":REM *** PV ***
310:GOSUB 900
320:C=(B+V*E)/W
330:R=C:GOSUB 910
340:PRINT "PV=",USING "########.##";R:END 
400:"V":REM *** PMT ***
410:GOSUB 900
420:V=(C*W-B)/E
430:R=V:GOSUB 910
440:PRINT "PMT=",USING "########.##";R:END 
500:"B":REM *** FV ***
510:GOSUB 900
520:B=C*W-V*E
530:R=B:GOSUB 910
540:PRINT "FV=",USING "########.##";R:END 
900:REM *** ANNUITY CALC ***
901:Q=1+X/100:W=Q^Z:E=(W-1)/(Q-1):RETURN
910:REM *** ROUND 1/100 ***
911:R=INT(R*100+.5)/100:RETURN
