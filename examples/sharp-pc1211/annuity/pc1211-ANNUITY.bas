PROGRAM "ANNUITY"
10:"A":REM "*** INPUT ALL VARIABLES ***"
20:INPUT "N:",Z
30:INPUT "I:",X
40:INPUT "PV:",C
50:INPUT "PMT:",V
60:INPUT "FV:",B:END
100:"Z":REM "*** SOLVE N ***"
110:I=0:U=0.01:Q=1+X/100:Z=270:INPUT "APPROX N (270):",Z
120:I=I+1:T=Z:GOSUB 700
130:Y=R:T=Z+U:GOSUB 700
140:O=Z:Z=O-U*Y/(R-Y)
150:IF ABS (O-Z)>=|E-8 THEN 120
160:R=Z:GOSUB 910:BEEP 2:PRINT "N=",USING "########.#";R
161:R=Z/12:GOSUB 910:PRINT "N/12=",USING "########.#";R
170:END
200:"X":REM "*** SOLVE I ***"
210:I=0:U=0.0001:X=0.6:INPUT "APPROX I (0.6):",X
211:X=1+X/100
220:I=I+1:T=X:GOSUB 800
230:Y=R:T=X+U:GOSUB 800
240:O=X:X=O-U*Y/(R-Y)
250:IF ABS (O-X)>=|E-6 THEN 220
260:X=(X-1)*100
261:R=X:GOSUB 930:BEEP 2:PRINT "I=",USING "#####.###";R
262:R=X*12:GOSUB 930:PRINT "I*12=",USING "#####.###";R
270:END
300:"C":REM "*** SOLVE PV ***"
310:GOSUB 900
320:C=(B+V*E)/W
330:R=C:GOSUB 920
340:PRINT "PV=",USING "########.##";R:END
400:"V":REM "*** SOLVE PMT ***"
410:GOSUB 900
420:V=(C*W-B)/E
430:R=V:GOSUB 920
440:PRINT "PMT=",USING "########.##";R:END
500:"B":REM "*** SOLVE FV ***"
510:GOSUB 900
520:B=C*W-V*E
530:R=B:GOSUB 920
540:PRINT "FV=",USING "########.##";R:END
700:REM "*** ROOT FOR N ***"
710:R=(Q^T-1)/(Q-1)*V-Q^T*C+B
720:RETURN
800:REM "*** ROOT FOR I ***"
810:R=(T^Z-1)/(T-1)*V-T^Z*C+B
820:RETURN
900:REM "*** ANNUITY BASICS ***"
901:Q=1+X/100:W=Q^Z:E=(W-1)/(Q-1):RETURN
910:REM "*** ROUND 1/10 ***"
911:R=INT(R*10+.5)/10:RETURN
920:REM "*** ROUND 1/100 ***"
921:R=INT(R*100+.5)/100:RETURN
930:REM "*** ROUND 1/1000 ***"
931:R=INT(R*1000+.5)/1000:RETURN
