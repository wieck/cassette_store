		images/approx-N-no-idea.png \
		images/approx-N-184.png \




all:	$(ALL)

clean:
	rm -f $(ALL)

images/cmd-new.png:
	convert -background $(BG) -fill $(FG) \
			-font $(FONT) -pointsize $(FONTSIZE) \
			-bordercolor $(BG) -border $(BORDER)x$(BORDER) \
			label:"NEW                     " \
			$@

