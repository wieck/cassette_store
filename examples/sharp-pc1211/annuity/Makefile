FONT = ../fonts/5x7-dot-matrix/5x7-dot-matrix.otf
FONTSIZE = 12
BG = "\#cccc00"
FG = black
BORDER = 4

ALL =	images/cmd-new.png \
		images/cmd-cload-annuity.png \
		images/prompt-N.png images/input-N.png \
		images/prompt-I.png images/input-I.png \
		images/prompt-PV.png images/input-PV.png \
		images/prompt-PMT.png \
		images/prompt-FV.png images/input-FV.png \
